{
    "form_template": {
        "title": "Kepatuhan Penggunaan APD",
        "description": "Form untuk evaluasi kepatuhan penggunaan alat pelindung diri di unit pelayanan kesehatan",
        "compliance_method": "auto_calculate",
        "auto_fail_on_critical": true
    },
    "form_fields": [
        {
            "field_key": "apd_completeness",
            "field_label": "Kelengkapan APD",
            "field_description": "Apakah petugas menggunakan APD lengkap sesuai standar?",
            "field_type": "single_select",
            "validation_config": {
                "required": true
            },
            "compliance_weight": 5,
            "is_critical_field": true,
            "order_index": 1,
            "options": [
                {
                    "option_text": "Lengkap dan sesuai standar ✅",
                    "option_value": "lengkap",
                    "is_correct": true
                },
                {
                    "option_text": "Kurang lengkap tapi minimal sesuai standar ⚠️",
                    "option_value": "kurang_lengkap",
                    "is_correct": true
                },
                {
                    "option_text": "Tidak lengkap/tidak sesuai standar ❌",
                    "option_value": "tidak_lengkap",
                    "is_correct": false
                }
            ]
        },
        {
            "field_key": "apd_usage",
            "field_label": "Cara Penggunaan APD",
            "field_description": "Apakah petugas menggunakan APD dengan cara yang benar?",
            "field_type": "single_select",
            "validation_config": {
                "required": true
            },
            "compliance_weight": 4,
            "is_critical_field": false,
            "order_index": 2,
            "options": [
                {
                    "option_text": "Benar semua ✅",
                    "option_value": "benar",
                    "is_correct": true
                },
                {
                    "option_text": "Ada sedikit kesalahan ⚠️",
                    "option_value": "sedikit_salah",
                    "is_correct": true
                },
                {
                    "option_text": "Banyak kesalahan ⚠️",
                    "option_value": "banyak_salah",
                    "is_correct": false
                },
                {
                    "option_text": "Salah total ❌",
                    "option_value": "salah",
                    "is_correct": false
                }
            ]
        },
        {
            "field_key": "apd_disposal",
            "field_label": "Pembuangan APD",
            "field_description": "Apakah petugas membuang APD sekali pakai dengan benar?",
            "field_type": "single_select",
            "validation_config": {
                "required": true
            },
            "compliance_weight": 3,
            "is_critical_field": false,
            "conditional_logic": {
                "depends_on_field": "apd_completeness",
                "condition_type": "show_when",
                "trigger_values": [
                    "lengkap",
                    "kurang_lengkap"
                ]
            },
            "order_index": 3,
            "options": [
                {
                    "option_text": "Ya, benar ✅",
                    "option_value": "ya",
                    "is_correct": true
                },
                {
                    "option_text": "Tidak/kurang tepat ❌",
                    "option_value": "tidak",
                    "is_correct": false
                },
                {
                    "option_text": "Tidak relevan (APD reusable)",
                    "option_value": "na",
                    "is_correct": true
                }
            ]
        },
        {
            "field_key": "additional_notes",
            "field_label": "Catatan Tambahan",
            "field_description": "Catatan observasi atau temuan lainnya",
            "field_type": "text",
            "validation_config": {
                "required": false,
                "max_length": 500
            },
            "compliance_weight": 0,
            "is_critical_field": false,
            "order_index": 4
        }
    ]
}