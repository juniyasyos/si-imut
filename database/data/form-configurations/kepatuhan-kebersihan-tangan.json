{
    "form_template": {
        "title": "Kepatuhan Kebersihan Tangan",
        "description": "Form sederhana untuk audit kepatuhan cuci tangan berdasarkan 5 momen WHO dan 6 langkah cuci tangan",
        "compliance_method": "auto_calculate",
        "auto_fail_on_critical": true
    },
    "form_fields": [
        {
            "field_key": "hand_hygiene_method",
            "field_label": "Cuci Tangan Dengan Apa",
            "field_description": "Metode cuci tangan yang digunakan oleh tenaga kesehatan",
            "field_type": "single_select",
            "validation_config": {
                "required": true
            },
            "compliance_weight": 3,
            "is_critical_field": true,
            "order_index": 1,
            "options": [
                {
                    "option_text": "Hand Rub (Antiseptik berbasis alkohol) ✅",
                    "option_value": "hand_rub",
                    "is_correct": true
                },
                {
                    "option_text": "Air + Sabun ✅",
                    "option_value": "air_sabun",
                    "is_correct": true
                },
                {
                    "option_text": "Tidak melakukan cuci tangan ❌",
                    "option_value": "tidak_cuci_tangan",
                    "is_correct": false
                }
            ]
        },
        {
            "field_key": "hand_hygiene_indication",
            "field_label": "Indikasi Cuci Tangan - 5 Momen WHO",
            "field_description": "Pilih indikasi cuci tangan sesuai 5 momen WHO (dapat memilih lebih dari satu)",
            "field_type": "multi_select",
            "validation_config": {
                "required": true,
                "min_selections": 1
            },
            "compliance_weight": 3,
            "is_critical_field": true,
            "compliance_rules": {
                "minimum_correct": 1,
                "allow_wrong_selections": true
            },
            "conditional_logic": {
                "depends_on_field": "hand_hygiene_method",
                "condition_type": "show_when",
                "trigger_values": [
                    "hand_rub",
                    "air_sabun"
                ]
            },
            "order_index": 2,
            "options": [
                {
                    "option_text": "Sebelum kontak dengan pasien",
                    "option_value": "sebelum_kontak_pasien",
                    "is_correct": true
                },
                {
                    "option_text": "Sebelum prosedur bersih/aseptik",
                    "option_value": "sebelum_prosedur_aseptik",
                    "is_correct": true
                },
                {
                    "option_text": "Setelah prosedur/risiko terpapar cairan tubuh",
                    "option_value": "setelah_risiko_cairan",
                    "is_correct": true
                },
                {
                    "option_text": "Setelah kontak dengan pasien",
                    "option_value": "setelah_kontak_pasien",
                    "is_correct": true
                },
                {
                    "option_text": "Setelah kontak dengan area sekitar pasien",
                    "option_value": "setelah_kontak_area_sekitar",
                    "is_correct": true
                }
            ]
        },
        {
            "field_key": "six_steps_compliance",
            "field_label": "6 Langkah Cuci Tangan",
            "field_description": "Checklist kepatuhan 6 langkah cuci tangan WHO (semua langkah harus dilakukan untuk compliance penuh)",
            "field_type": "multi_select",
            "validation_config": {
                "required": false
            },
            "compliance_weight": 5,
            "is_critical_field": true,
            "compliance_rules": {
                "minimum_correct": 6,
                "allow_wrong_selections": true
            },
            "conditional_logic": {
                "depends_on_field": "hand_hygiene_method",
                "condition_type": "show_when",
                "trigger_values": [
                    "hand_rub",
                    "air_sabun"
                ]
            },
            "order_index": 3,
            "options": [
                {
                    "option_text": "Gosok kedua telapak tangan",
                    "option_value": "gosok_telapak_tangan",
                    "is_correct": true
                },
                {
                    "option_text": "Gosok punggung-sela jari kanan-kiri",
                    "option_value": "gosok_punggung_sela_jari",
                    "is_correct": true
                },
                {
                    "option_text": "Gosok kedua telapak dan sela jari",
                    "option_value": "gosok_telapak_sela_jari",
                    "is_correct": true
                },
                {
                    "option_text": "Jari sisi dalam kedua tangan mengunci",
                    "option_value": "jari_sisi_dalam_mengunci",
                    "is_correct": true
                },
                {
                    "option_text": "Gosok ibu jari berputar dlm genggaman",
                    "option_value": "gosok_ibu_jari_berputar",
                    "is_correct": true
                },
                {
                    "option_text": "Ujung jari berputar ke telapak kanan-kiri",
                    "option_value": "ujung_jari_berputar",
                    "is_correct": true
                }
            ]
        }
    ]
}