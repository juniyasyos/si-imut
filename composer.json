{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "juniyasyos/siimut",
    "type": "project",
    "description": "SIIMUT is a Laravel-based application designed to assist hospital in managing and monitoring accreditaion quality effectively.",
    "keywords": [
        "laravel",
        "siimut",
        "rscitrahusada",
        "framework",
        "filament",
        "admin-panel",
        "starter-kit"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "archilex/filament-toggle-icon-column": "^3.2",
        "asmit/resized-column": "^1.0",
        "awcodes/filament-table-repeater": "^3.1",
        "bepsvpt/secure-headers": "^9.0",
        "bezhansalleh/filament-language-switch": "^3.1",
        "bezhansalleh/filament-shield": "^3.3",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "dedoc/scramble": "^0.12.10",
        "diogogpinto/filament-auth-ui-enhancer": "^1.0",
        "dutchcodingcompany/filament-socialite": "^2.3",
        "filament/filament": "^3.2",
        "filament/spatie-laravel-media-library-plugin": "^3.2",
        "filament/spatie-laravel-settings-plugin": "^3.2",
        "firebase/php-jwt": "^6.11",
        "guava/filament-modal-relation-managers": "^1.4",
        "icetalker/filament-table-repeater": "^1.4",
        "jeffgreco13/filament-breezy": "^2.4",
        "juniyasyos/dash-stack-theme-juniyasyos": "^1.3",
        "juniyasyos/filament-backup": "^1.2",
        "juniyasyos/filament-media-manager": "v1.3.7",
        "juniyasyos/filament-pwa-kaido": "^2.1",
        "juniyasyos/filament-settings-hub-kaido": "^4.0",
        "juniyasyos/laravel-iam-client": "v1.3.0",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.0",
        "leandrocfe/filament-apex-charts": "^3.2",
        "njxqlus/filament-progressbar": "*",
        "nwidart/laravel-modules": "^12.0",
        "owenvoke/blade-fontawesome": "^2.8",
        "pxlrbt/filament-excel": "^2.3",
        "resend/resend-laravel": "^0.16.1",
        "rmsramos/activitylog": "^1.0",
        "socialiteproviders/google": "^4.1",
        "spatie/browsershot": "^5.0",
        "spatie/laravel-permission": "^6.23",
        "stechstudio/filament-impersonate": "^3.15",
        "torgodly/html2media": "^1.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "barryvdh/laravel-ide-helper": "^3.5",
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "^4.0",
        "laravel-shift/blueprint": "^2.10",
        "laravel/pail": "^1.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.6",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-stressless": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Juniyasyos\\FilamentMediaManager\\": "packages/juniyasyos/filament-media-manager/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi",
            "@php artisan storage:link"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" --kill-others-on-fail --restart-tries=3 \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=300\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "iam": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --port=8088\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "dev-lara": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan serve\" \"php -d max_execution_time=0 artisan queue:work --tries=1 --timeout=400 \" \"php artisan pail --timeout=0\" --names=server,queue,logs"
        ],
        "setup": [
            "Composer\\Config::disableProcessTimeout",
            "git clean -f && git reset --hard && git pull",
            "rm -rf ./storage/debugbar/*.json",
            "@php artisan migrate:fresh --seed",
            "@php artisan shield:generate --all --panel=admin",
            "@php artisan shield:super-admin --user=1",
            "git clean -f && git reset --hard"
        ],
        "prod-setup": [
            "git clean -f && git reset --hard && git pull",
            "rm -rf ./storage/debugbar/*.json",
            "@php artisan migrate:fresh",
            "@php artisan db:seed --class=DatabaseProductionSeeder",
            "@php artisan shield:generate --all --panel=admin",
            "@php artisan shield:super-admin --user=1",
            "git clean -f && git reset --hard"
        ],
        "dev-setup": [
            "@php artisan shield:generate --option=permissions --panel=admin"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}