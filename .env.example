OCTANE_SERVER=frankenphp
DEBUGBAR_ENABLED=false
SCOUT_SEARCH_LIMIT=50
BACKUP_ARCHIVE_PASSWORD='password-backup'

# -----------------------------------------------------------------------------
# Identity & Access Management (SSO Configuration)
# -----------------------------------------------------------------------------
# Set to true to use SSO authentication (production)
# Set to false to use custom Filament login with NIP/Password (development)
USE_SSO=true
IAM_ENABLED=true

# IAM Server Configuration
IAM_HOST=http://127.0.0.1:8010
IAM_VERIFY_ENDPOINT=${IAM_HOST}/api/sso/verify
IAM_APP_KEY=siimut

# IAM SSO Client Package Configuration
IAM_BASE_URL=${IAM_HOST}
IAM_LOGIN_ROUTE=/login
IAM_CALLBACK_ROUTE=/callback
IAM_DEFAULT_REDIRECT=/
IAM_GUARD=web
IAM_USER_MODEL=App\Models\User
IAM_IDENTIFIER_FIELD=nip
IAM_PRESERVE_SESSION_ID=true
IAM_SYNC_ROLES=true
IAM_ROLE_GUARD_NAME=web
IAM_STORE_TOKEN_IN_SESSION=true
# Role sync direction: push = IAM sends roles to client (create them automatically)
IAM_ROLE_SYNC_MODE=push
# Allow role creation on client from IAM during sync (required for push mode to actually create roles)
IAM_ROLE_SYNC_FROM_IAM_ALLOW_CREATE=true
# Shared secret for backchannel verification (if IAM_BACKCHANNEL_VERIFY enabled)
SSO_SECRET=siimut_secret_key_123
IAM_BACKCHANNEL_METHOD=jwt
# Temporarily disable backchannel verification for testing endpoint connectivity
IAM_BACKCHANNEL_VERIFY=true
IAM_ISSUER=${IAM_HOST}
IAM_USER_APPLICATIONS_ENDPOINT=${IAM_HOST}/api/users/applications/detail
IAM_JWT_SECRET=base64:G8w0qytVP8V+Mml5pYqm90R9m7AdfltGk1GCXMGq2qw=

# Token Verification Settings - CRITICAL for session expiration enforcement
# Verify JWT token on every request to ensure token hasn't expired on IAM
IAM_VERIFY_EACH_REQUEST=true
# Also verify with IAM server to catch revoked/expired tokens server-side
IAM_VERIFY_REMOTE_EACH_REQUEST=true
# IMPORTANT: Attach middleware automatically to web routes for proper token checking
IAM_ATTACH_VERIFY_MIDDLEWARE=true

# Session Lifetime Synchronization with Token Expiry
# When enabled, session lifetime is automatically synced with JWT token expiry
# This ensures session doesn't outlive the token (security best practice)
IAM_SYNC_SESSION_LIFETIME=true
# Buffer in minutes subtracted from token TTL when calculating session lifetime
# Example: Token TTL 60min - Buffer 2min = Session lifetime 58min
# Prevents edge cases where token expires mid-request
IAM_SESSION_LIFETIME_BUFFER=2